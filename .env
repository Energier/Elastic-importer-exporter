# =========================================
# Elasticsearch connections
# =========================================

# SOURCE (used by eksporter.py)
SOURCE_ES_LINK=https://elastic:MJUHjurscyZsDOhcrd2O@srv.dmsales.io:8443
SOURCE_ES_VERIFY_CERTS=false

# DESTINATION (used by importer.py)
DEST_ES_LINK=http://dmsales.test.dmsales.com:9200
DEST_ES_VERIFY_CERTS=false


# =========================================
# Shared files/paths
# =========================================

INPUT_FILE=indexes.csv
INDEX_COLUMN=index_name
OUTPUT_DIRECTORY=elastic_export
REQUEST_TIMEOUT=300
ES_CLIENT_MAX_RETRIES=5
ES_OPERATION_MAX_RETRIES=3
ES_RETRY_BACKOFF_SECONDS=3
ES_RETRY_BACKOFF_MAX_SECONDS=60

# =========================================
# Exporter settings (eksporter.py)
# =========================================

EXPORT_SUMMARY_FILE=export_summary.csv
EXPORT_DRY_RUN=false
BATCH_SIZE=1000
SCROLL_TIME=10m
CSV_DELIMITER=;
CSV_ENCODING=utf-8-sig
FLUSH_EVERY=1000
PROGRESS_EVERY=10000
ES_SCAN_MAX_RETRIES=3

# NDJSON export options (ES 6.8)
BULK_OPERATION=index
NDJSON_INCLUDE_INDEX_NAME=true
NDJSON_INCLUDE_DOCUMENT_TYPE=true
NDJSON_DOCUMENT_TYPE_FALLBACK=_doc

# =========================================
# Importer settings (importer.py)
# =========================================

IMPORT_INPUT_FILE=import_indexes.csv
IMPORT_SUMMARY_FILE=import_summary.csv
IMPORT_DRY_RUN=false
IMPORT_BATCH_SIZE=1000
IMPORT_BULK_MAX_RETRIES=3
IMPORT_BULK_INITIAL_BACKOFF_SECONDS=2
IMPORT_BULK_MAX_BACKOFF_SECONDS=120
IMPORT_VALIDATE_FILES=true
IMPORT_VALIDATE_COUNTS=true
IMPORT_VALIDATE_AFTER_UPLOAD=true
IMPORT_POST_VALIDATE_STRICT=true
IMPORT_POST_VALIDATE_RETRIES=5
IMPORT_POST_VALIDATE_DELAY_SECONDS=1
IMPORT_OVERWRITE_EXISTING=false
IMPORT_APPLY_ALIASES=true
IMPORT_REQUIRE_ES6=true
IMPORT_DOCUMENT_TYPE_FALLBACK=_doc
